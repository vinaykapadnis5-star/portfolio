// Reusable Components
@Component
public class TestDataManager {
    
    private Properties config;
    private static ThreadLocal<Map<String, String>> testData = new ThreadLocal<>();
    
    public String getConfig(String key) {
        return config.getProperty(key);
    }
    
    public void setTestData(String key, String value) {
        if (testData.get() == null) {
            testData.set(new HashMap<>());
        }
        testData.get().put(key, value);
    }
    
    public String getTestData(String key) {
        return testData.get().get(key);
    }
}
